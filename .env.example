# ─── LLM (Groq — gratuit) ─────────────────────────────
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MODEL=llama-3.3-70b-versatile

# ─── Base de données ──────────────────────────────────
# Docker gère automatiquement postgres — ne pas changer
DATABASE_URL=postgresql://user:password@postgres:5432/platform

# ─── Redis ────────────────────────────────────────────
# Docker gère automatiquement redis — ne pas changer
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,null

# ─── ERPNext (VOS VRAIES VALEURS ICI) ─────────────────
#
# IMPORTANT — choisir la bonne URL selon votre config :
#
#   ERPNext sur la même machine (hors Docker) :
#     ERPUIUX_URL=http://host.docker.internal:8080
#
#   ERPNext sur un serveur distant :
#     ERPUIUX_URL=http://192.168.X.X:8080
#
#   ERPNext dans la même stack Docker :
#     ERPUIUX_URL=http://erpnext:8080
#
ERPUIUX_URL=http://host.docker.internal:8080
ERPUIUX_API_KEY=VOTRE_API_KEY_ERPNEXT
ERPUIUX_SECRET=VOTRE_SECRET_ERPNEXT
ERPUIUX_SITE=localhost

# Pour obtenir API Key + Secret dans ERPNext :
#   Paramètres → Utilisateurs → votre user → section "Clés API" → Générer

# ─── Circuit Breaker ──────────────────────────────────
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RECOVERY_TIMEOUT=120

# ─── HITL ─────────────────────────────────────────────
HITL_CONFIDENCE_THRESHOLD=0.80
HITL_TIMEOUT_SECONDS=3600
HITL_FALLBACK_APPROVE=true
HITL_WEBHOOK_URL=

# ─── Cost Alerting ────────────────────────────────────
COST_BUDGET_THRESHOLD=10.00
COST_ALERT_EMAIL=

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_STARTER=10
RATE_LIMIT_PRO=60
RATE_LIMIT_ENTERPRISE=0
